# Groq API key — STT + TTS. Get one at https://console.groq.com
GROQ_API_KEY=

# Anthropic API key — used by the Claude Agent SDK
ANTHROPIC_API_KEY=

# Model for the spoken answer (env-configurable; Sonnet chosen for voice latency)
ANSWER_MODEL=claude-sonnet-4-6

# Groq model/voice ids (override here if they drift)
STT_MODEL=whisper-large-v3-turbo
TTS_MODEL=canopylabs/orpheus-v1-english
TTS_VOICE=Hannah

# Server port
PORT=8787
